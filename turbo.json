{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^prepare"],
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": [".svelte-kit/**", "build/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"format": {
			"cache": false
		},
		"prepare": {
			"cache": false
		},
		"preview": {
			"env": ["DATABASE_URL", "MEDIAMTX_HOST", "RECORD_PATH"],
			"cache": false,
			"persistent": true
		},
		"db:migrate": {
			"env": ["DATABASE_URL"],
			"cache": false
		},
		"dev": {
			"env": ["DATABASE_URL", "MEDIAMTX_HOST", "RECORD_PATH"],
			"cache": false,
			"persistent": true
		}
	}
}
