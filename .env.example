# Environment variable file for Multiview.

# 0. Duplicate this file, and rename the file ".env".

# 1. Put your hostname here.
HOST=10.0.0.110
# 2. Put your MediaMTX's Control API hostname here.
MEDIAMTX_HOST=127.0.0.1
# 3. Where did you store your VOD? (absolute path is strictly required)
RECORD_PATH="/recording/path"
# 4. It is recommended to leave here as it is, or change the database URL if you really want to do.
#    If you want to change the database (SQLite to postgres), change the following line of code below.
#    File: ./prisma/schema.prisma
#    datasource db {
#       provider = "sqlite" <- change this thingy here.
#    }
#    Check the documentation for all the connection string options (depends on the database that you use): 
#    https://pris.ly/d/connection-strings
DATABASE_URL="file:./db/prismaSqlite.db"
# 5. Put your dev and production port number for hosting a site (80 for http, 443 for https, or any ports that won't interfere
#    with ports already used in your host system, MediaMTX ports (9997, 8890, 8888), and backend ports (3000-3999))
DEV_PORT=80
PROD_PORT=80